<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>روزنامة فعاليات مجلس عائلة الدريع 1448 هـ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        body {
            font-family: 'Tajawal', sans-serif;
            /* خلفية ليلية هادئة وفخمة لنخيل الأحساء تناسب وقار العائلة والمظهر الغامر */
            background: url('https://images.unsplash.com/photo-1541252260730-0412e8e2108e?q=80&w=1920&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
            overflow-x: hidden;
        }
        
        .immersive-container {
            background: rgba(255, 255, 255, 0.22);
            backdrop-filter: blur(25px) saturate(160%);
            -webkit-backdrop-filter: blur(25px) saturate(160%);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.2);
        }

        .spatial-bento-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.7);
            cursor: pointer;
            transform-style: preserve-3d;
            will-change: transform;
            transition: transform 0.15s ease-out, background-color 0.4s ease, box-shadow 0.4s ease;
        }

        .spatial-bento-card-critical {
            background: rgba(254, 242, 242, 0.75);
            border-color: rgba(252, 165, 165, 0.6);
        }

        /* نافذة العرض الموسع الفاخرة */
        .premium-modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 50;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }
    </style>
</head>
<body class="text-gray-800 min-h-screen py-8 px-4 sm:px-6 lg:px-8 flex items-center justify-center">

    <div class="immersive-container w-full max-w-6xl rounded-[32px] p-6 md:p-10 my-2 relative">
        
        <div class="text-center border-b border-white/30 pb-6 mb-8">
            <div class="inline-flex items-center gap-2 bg-emerald-950/90 border border-emerald-700 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-md mb-4">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                الدورة الحالية الإدارية: سنتين كاملتين (1448 هـ - 1449 هـ)
            </div>
            <h1 class="text-2xl md:text-4xl font-black text-gray-900 tracking-tight flex items-center justify-center gap-2 mt-1">
                <i class="fa-solid fa-palm-tree text-emerald-800"></i>
                روزنامة فعاليات مجلس عائلة الدريع بالأحساء
            </h1>
            <p class="text-gray-700 text-xs sm:text-sm mt-1.5 font-semibold">انقر على أي بطاقة لعرض التفاصيل الكاملة والمهام الإدارية</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            
            <div class="spatial-bento-card spatial-bento-card-critical rounded-[22px] p-5 flex flex-col justify-between min-h-[250px]" onclick="openModal('deadline')">
                <div>
                    <div class="flex justify-between items-center mb-4">
                        <div class="w-9 h-9 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-600 shadow-sm">
                            <i class="fa-solid fa-triangle-exclamation text-base"></i>
                        </div>
                        <span class="text-[10px] font-black text-red-700 bg-red-100/60 border border-red-200/60 px-2 py-0.5 rounded-full">تنظيم مالي</span>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-1">📌 الموعد النهائي للسداد</h3>
                    <p class="text-gray-600 text-xs sm:text-sm leading-relaxed">آخر يوم لتأكيد وجمع الاشتراكات السنوية من أفراد العائلة الكرام لتسهيل إتمام الحجوزات السنوية للمجلس.</p>
                </div>
                <div class="text-xs font-black font-mono text-center text-red-600 bg-white/90 py-2 rounded-xl mt-4 border border-white/90 shadow-inner" id="timer-deadline">جاري الحساب...</div>
            </div>

            <div class="spatial-bento-card rounded-[22px] p-5 flex flex-col justify-between min-h-[250px]" onclick="openModal('winter')">
                <div>
                    <div class="flex justify-between items-center mb-4">
                        <div class="w-9 h-9 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-800 shadow-sm">
                            <i class="fa-solid fa-snowflake text-base"></i>
                        </div>
                        <span class="text-[10px] font-black text-emerald-800 bg-emerald-100/60 border border-emerald-200/60 px-2 py-0.5 rounded-full">الملتقى الأول</span>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-1">❄️ الحفل الشتوي السنوي</h3>
                    <p class="text-gray-600 text-xs sm:text-sm leading-relaxed">اللقاء العائلي الموسع للمجلس وعرض التقارير السنوية وتكريم المتميزين والمبدعين من أبناء العائلة.</p>
                </div>
                <div class="text-xs font-black font-mono text-center text-emerald-800 bg-white/90 py-2 rounded-xl mt-4 border border-white/90 shadow-inner" id="timer-winter">جاري الحساب...</div>
            </div>

            <div class="spatial-bento-card rounded-[22px] p-5 flex flex-col justify-between min-h-[250px]" onclick="openModal('ramadan')">
                <div>
                    <div class="flex justify-between items-center mb-4">
                        <div class="w-9 h-9 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-800 shadow-sm">
                            <i class="fa-solid fa-mosque text-base"></i>
                        </div>
                        <span class="text-[10px] font-black text-emerald-800 bg-emerald-100/60 border border-emerald-200/60 px-2 py-0.5 rounded-full">روحانيات</span>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-1">🌙 الإفطار الرمضاني المبارك</h3>
                    <p class="text-gray-600 text-xs sm:text-sm leading-relaxed">اجتماع مبارك يجمع قلوب بني العمومة على مائدة واحدة لتوثيق أواصر القربى والرحمة في الشهر الفضيل.</p>
                </div>
                <div class="text-xs font-black font-mono text-center text-emerald-800 bg-white/90 py-2 rounded-xl mt-4 border border-white/90 shadow-inner" id="timer-ramadan">جاري الحساب...</div>
            </div>

            <div class="spatial-bento-card rounded-[22px] p-5 flex flex-col justify-between min-h-[250px]" onclick="openModal('eid-fitr')">
                <div>
                    <div class="flex justify-between items-center mb-4">
                        <div class="w-9 h-9 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-700 shadow-sm">
                            <i class="fa-solid fa-wand-magic-sparkles text-base"></i>
                        </div>
                        <span class="text-[10px] font-black text-emerald-800 bg-emerald-100/60 border border-emerald-200/60 px-2 py-0.5 rounded-full">بهجة العيد</span>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-1">🎈 ملتقى عيد الفطر السعيد</h3>
                    <p class="text-gray-600 text-xs sm:text-sm leading-relaxed">المعايدة السنوية الكبرى وتوزيع هدايا العيد على الأطفال والاحتفاء بصلات الرحم والترابط العائلي السعيد.</p>
                </div>
                <div class="text-xs font-black font-mono text-center text-emerald-800 bg-white/90 py-2 rounded-xl mt-4 border border-white/90 shadow-inner" id="timer-eid-fitr">جاري الحساب...</div>
            </div>

            <div class="spatial-bento-card rounded-[22px] p-5 flex flex-col justify-between min-h-[250px]" onclick="openModal('eid-adha')">
                <div>
                    <div class="flex justify-between items-center mb-4">
                        <div class="w-9 h-9 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-700 shadow-sm">
                            <i class="fa-solid fa-handshake-angle text-base"></i>
                        </div>
                        <span class="text-[10px] font-black text-emerald-800 bg-emerald-100/60 border border-emerald-200/60 px-2 py-0.5 rounded-full">ختام الدورة</span>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-1">🐑 ملتقى عيد الأضحى المبارك</h3>
                    <p class="text-gray-600 text-xs sm:text-sm leading-relaxed">اجتماع المعايدة السنوي السعيد لتبادل التهاني وتكامل الجهود لتنمية وتكامل الصندوق العائلي للمجلس.</p>
                </div>
                <div class="text-xs font-black font-mono text-center text-emerald-800 bg-white/90 py-2 rounded-xl mt-4 border border-white/90 shadow-inner" id="timer-eid-adha">جاري الحساب...</div>
            </div>

        </div>

        <div class="mt-8 bg-white/10 border border-white/20 rounded-xl p-3 text-center backdrop-blur-sm">
            <p class="text-[11px] sm:text-xs text-gray-900 font-bold">تنويه تنظيمي: جميع التواريخ تتبع تقويم أم القرى المعتمد لمجلس العائلة بالأحساء.</p>
        </div>
    </div>

    <div id="detailModal" class="premium-modal" onclick="closeModal(event)">
        <div class="bg-white/95 border border-white max-w-lg w-full rounded-[28px] p-6 md:p-8 shadow-2xl relative animate-scale-up max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
            <button class="absolute top-4 left-4 w-8 h-8 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center text-gray-500 transition-colors" onclick="closeModal(null)">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
            <div id="modalContent"></div>
        </div>
    </div>

    <script>
        // تأثير الماوس ثلاثي الأبعاد المتطور للكروت
        const cards = document.querySelectorAll('.spatial-bento-card');
        cards.forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const angleX = ((rect.height / 2) - (e.clientY - rect.top)) / 10;
                const angleY = ((e.clientX - rect.left) - (rect.width / 2)) / 10;
                card.style.transform = `perspective(800px) rotateX(${angleX}deg) rotateY(${angleY}deg) translateY(-5px)`;
                card.style.boxShadow = `0 15px 30px -10px rgba(0,0,0,0.15)`;
                card.style.backgroundColor = 'rgba(255, 255, 255, 0.85)';
            });
            card.addEventListener('mouseleave', () => {
                card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg) translateY(0px)';
                card.style.boxShadow = 'none';
                card.style.backgroundColor = card.classList.contains('spatial-bento-card-critical') ? 'rgba(254, 242, 242, 0.75)' : 'rgba(255, 255, 255, 0.75)';
            });
        });

        // بيانات العرض الموسع التفصيلي الكامل بناء على مستندات المجلس
        const detailsData = {
            deadline: {
                title: "📌 التفاصيل الكاملة للموعد النهائي للسداد",
                dateH: "30 جمادى الأولى 1448 هـ", dateM: "09 نوفمبر 2026 م",
                desc: "إجراء تنظيمي مالي حرج للغاية. يهدف إلى حصر الميزانية المتوفرة مبكراً لدى كبار العائلة ممثلة بالعم (أبو هاني) لضمان حجز المواقع وتجهيز متطلبات المناسبات القادمة بقرارات إدارية دقيقة.",
                rules: [
                    "يتم إرسال التذكيرات بشكل دوري لضمان عدم تأخر أي عضو.",
                    "تكرار تأخر أو غياب العضو بدون عذر رسمي مقبول يؤدي إلى مراجعة عضويته في الإدارة فوراً.",
                    "تُرفع التقارير المالية مباشرة للمشرف العام لاعتماد الميزانيات التشغيلية للملتقيات."
                ]
            },
            winter: {
                title: "❄️ تفاصيل الحفل الشتوي السنوي (الملتقى الأول)",
                dateH: "09 رجب 1448 هـ", dateM: "18 ديسمبر 2026 م",
                desc: "الملتقى الرسمي الأكبر لعرض إنجازات الدورة الإدارية الحالية وتكريم المتميزين والمبدعين، بالإضافة إلى توثيق روابط العمومة والأخوة بين أفراد العائلة.",
                rules: [
                    "المسؤول التنفيذي (محمد بن حسن): تأمين الوجبات الرئيسية بالتنسيق مع المطاعم ومواعيد التوصيل الدقيقة.",
                    "المسؤول التنفيذي (سعود بن علي): توفير كافة ملحقات الملتقى من مشروبات، فواكه، سلطات والمواد الاستهلاكية.",
                    "الإشراف الميداني الكامل على تحضير وتجهيز وجبة الطعام في يوم الملتقى تقع على عاتق اللجان المعنية بمساندة المشرف العام."
                ]
            },
            ramadan: {
                title: "🌙 تفاصيل الإفطار الرمضاني المبارك",
                dateH: "05 رمضان 1448 هـ", dateM: "12 فبراير 2027 م (متوقع)",
                desc: "أجواء روحانية رمضانية تجمع العائلة الكريمة في الأحساء على مائدة إفطار واحدة، لتعزيز صلة الرحم والتواصل الاجتماعي المستمر في هذا الشهر الفضيل.",
                rules: [
                    "يتم تحديد الموعد والموقع المناسب بناءً على تشاور وتوافق جميع أعضاء الإدارة لضمان حضور الجميع.",
                    "يُعد حضور جميع أعضاء الإدارة مبكراً والانصراف متأخراً في يوم الملتقى واجباً أساسياً لضمان نجاح التنظيم واستقبال الضيوف."
                ]
            },
            "eid-fitr": {
                title: "🎈 تفاصيل ملتقى عيد الفطر السعيد",
                dateH: "04 شوال 1448 هـ", dateM: "12 مارس 2027 م (متوقع)",
                desc: "الاحتفالية الكبرى لبهجة العيد، المخصصة لمعايدة كبار السن، وتوزيع العيادي والهدايا والجوائز على الأطفال لبث روح البهجة والترابط الأسري العريق.",
                rules: [
                    "التنسيق المالي المسبق مع الصندوق لاستلام المبالغ والمصاريف المخصصة لإقامة الملتقى والجوائز والهدايا.",
                    "يعقد اجتماع تقييمي مغلق ومباشر بين أعضاء الإدارة فور انتهاء الملتقى لرصد الأداء وتطويره للمناسبات القادمة."
                ]
            },
            "eid-adha": {
                title: "🐑 تفاصيل ملتقى عيد الأضحى المبارك",
                dateH: "13 ذو الحجة 1448 هـ", dateM: "19 مايو 2027 م (متوقع)",
                desc: "ملتقى المعايدة السعيد الثاني خلال العام، ويشهد مراجعة صندوق العائلة الختامي للدورة الإدارية الحالية لضمان استدامة المشاريع العائلية بنجاح واقتدار.",
                rules: [
                    "استعراض الحساب الختامي والتقارير المالية والتشغيلية المعتمدة لعام 1448 هـ.",
                    "تكريم لجان العمل التنفيذية التي ساهمت في إنجاح الروزنامة طوال السنة."
                ]
            }
        };

        function openModal(id) {
            const data = detailsData[id];
            const content = document.getElementById('modalContent');
            
            let listItems = data.rules.map(r => `<li class="mb-2 flex items-start gap-2 text-gray-700 text-sm md:text-base leading-relaxed"><span class="text-emerald-800 font-bold mt-1">•</span><span>${r}</span></li>`).join('');

            content.innerHTML = `
                <h2 class="text-xl md:text-2xl font-black text-gray-900 mb-4 border-b pb-3">${data.title}</h2>
                <div class="flex gap-4 bg-gray-50 p-3 rounded-xl border border-gray-200 text-xs md:text-sm font-bold mb-5">
                    <div><span class="text-gray-500 block">الهجري:</span> <span class="text-gray-900">${data.dateH}</span></div>
                    <div><span class="text-gray-500 block">الميلادي:</span> <span class="text-emerald-800">${data.dateM}</span></div>
                </div>
                <p class="text-gray-700 text-sm md:text-base leading-relaxed font-medium mb-4">${data.desc}</p>
                <h4 class="text-sm font-bold text-gray-900 mb-2 mt-4 flex items-center gap-1"><i class="fa-solid fa-clipboard-list text-emerald-800"></i> ضوابط وقوانين العمل والمسؤوليات:</h4>
                <ul class="pr-1">${listItems}</ul>
            `;
            
            const modal = document.getElementById('detailModal');
            modal.style.display = 'flex';
        }

        function closeModal(e) {
            if (!e || e.target === document.getElementById('detailModal')) {
                document.getElementById('detailModal').style.display = 'none';
            }
        }

        // كود العدادات التنازلية
        const targetDates = {
            deadline: new Date("Nov 9, 2026 23:59:59").getTime(),
            winter: new Date("Dec 18, 2026 16:00:00").getTime(),
            ramadan: new Date("Feb 12, 2027 17:30:00").getTime(),
            "eid-fitr": new Date("Mar 12, 2027 16:00:00").getTime(),
            "eid-adha": new Date("May 19, 2027 16:00:00").getTime()
        };

        function updateTimers() {
            const now = new Date().getTime();
            for (let id in targetDates) {
                const element = document.getElementById(`timer-${id}`);
                if (!element) continue;
                const diff = targetDates[id] - now;
                if (diff < 0) {
                    element.innerHTML = "✓ انقضت المناسبة بنجاح";
                    element.className = "text-xs font-bold text-center text-gray-400 bg-white/40 py-2 rounded-xl shadow-inner";
                    continue;
                }
                const d = Math.floor(diff / (1000 * 60 * 60 * 24));
                const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                element.innerHTML = `⏳ متبقي: ${d} يوم و ${h} ساعة`;
            }
        }
        setInterval(updateTimers, 60000);
        updateTimers();
    </script>
</body>
</html>
